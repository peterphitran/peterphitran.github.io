---
import { Icon } from "astro-icon/components";

const moreItems = [
    { name: "Experience",    path: "/#experience" },
    { name: "Projects",      path: "/#projects" },
    { name: "Volunteer",     path: "/#volunteer" },
    { name: "Coursework",    path: "/#coursework" },
    { name: "Certificates",  path: "/#certificates" },
    { name: "Skills",        path: "/#skills" },
];
---

<header class="w-full">
    <div
        class="font-sans mx-auto box-content flex h-8 max-w-5xl flex-row items-center justify-end px-5 sm:px-10 py-5"
    >
        <nav class="text-base text-secondary">
            <!-- Desktop -->
            <menu class="flex flex-row items-center gap-6 max-sm:hidden">
                <li>
                    <a href="/" class="hover:text-primary transition-colors duration-200 underline-offset-4 hover:underline">Home</a>
                </li>
                <li>
                    <a href="/gallery" class="hover:text-primary transition-colors duration-200 underline-offset-4 hover:underline">Gallery</a>
                </li>
                <li>
                    <a href="/open-source" class="hover:text-primary transition-colors duration-200 underline-offset-4 hover:underline">Open Source</a>
                </li>
                <li>
                    <a href="/topics" class="hover:text-primary transition-colors duration-200 underline-offset-4 hover:underline">Topics</a>
                </li>
                <!-- More dropdown -->
                <li class="relative">
                    <details id="more-dropdown" class="group/more">
                        <summary class="flex items-center gap-1 cursor-pointer list-none [&::-webkit-details-marker]:hidden hover:text-primary transition-colors duration-200">
                            More
                            <Icon name="fa7-solid:chevron-down" class="size-2.5 transition-transform duration-200 group-open/more:rotate-180" />
                        </summary>
                        <div class="absolute top-full right-0 pt-1 z-40">
                            <div class="w-44 bg-background border border-border rounded-lg shadow-md p-3">
                                <ul class="flex flex-col gap-2">
                                    {moreItems.map(({ path, name }) => (
                                        <li>
                                            <a href={path} class="block text-secondary hover:text-primary transition-colors duration-200 py-0.5">{name}</a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                    </details>
                </li>
            </menu>

            <!-- Mobile hamburger -->
            <details id="hamburger" class="peer group hidden max-sm:block relative">
                <summary class="inline cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                    <Icon name="fa7-solid:bars" class="inline group-open:hidden" role="button" aria-label="nav menu" />
                </summary>
                <div class="bg-background text-primary border border-border rounded-lg shadow-md p-5 absolute top-0 right-0 w-44 z-40">
                    <menu class="flex flex-col gap-3 text-sm text-right text-secondary">
                        <li><a href="/" class="hover:text-primary transition-colors duration-200">Home</a></li>
                        <li><a href="/gallery" class="hover:text-primary transition-colors duration-200">Gallery</a></li>
                        <li><a href="/open-source" class="hover:text-primary transition-colors duration-200">Open Source</a></li>
                        <li><a href="/topics" class="hover:text-primary transition-colors duration-200">Topics</a></li>
                        <li class="pt-2 border-t border-border text-xs uppercase tracking-widest text-secondary/60">More</li>
                        {moreItems.map(({ path, name }) => (
                            <li>
                                <a href={path} class="hover:text-primary transition-colors duration-200">{name}</a>
                            </li>
                        ))}
                    </menu>
                </div>
            </details>
        </nav>
    </div>
</header>

<script>
    const hamburger = document.getElementById("hamburger") as HTMLDetailsElement | null;
    const moreDropdown = document.getElementById("more-dropdown") as HTMLDetailsElement | null;

    document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (hamburger && hamburger.open && !hamburger.contains(target)) {
            hamburger.open = false;
        }
        if (moreDropdown && moreDropdown.open && !moreDropdown.contains(target)) {
            moreDropdown.open = false;
        }
    });
</script>