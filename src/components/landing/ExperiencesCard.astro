---
import { Image } from "astro:assets";

import jpmcLogo from "@/content/experiences/jpmc.png";
import beautisolLogo from "@/content/experiences/beautisol.png";
import misdLogo from "@/content/experiences/misd.png";
import craLogo from "@/content/experiences/CRA.png";
import awsLogo from "@/content/experiences/awslogo.png";

interface Experience {
    logo?: ImageMetadata,
    company: string,
    role: string,
    duration: string,
    description: string[],
    technologies?: string[],    
    link?: string,
}

const experiences: Experience[] = [
    {
        logo: jpmcLogo,
        company: "JP Morgan Chase",
        role: "Incoming Software Engineer Intern",
        duration: "Summer 2026",
        description: [
            "Part of the SEP Program"
        ],
    },
    {
        logo: craLogo,
        company: "UR2PhD Program",
        role: "Apprenticeship",
        duration: "Summer 2026",
        description: [
            "Selected apart of the Summer 2026 cohort (1 of 2 under Dr. Shomer apart of DIAL Labs at UT Arlington)."
        ],
    },
    {
        logo: awsLogo,
        company: "AWS Student Builder Campus Leader",
        role: "Campus Leader",
        duration: "March 2026 – Present",
        description: [
            "Representing AWS on campus, organizing cloud workshops and connecting students with AWS resources and programs."
        ],
        technologies: ["AWS"],
    },
    {
        logo: beautisolLogo,
        company: "Beautisol",
        role: "Software Development Intern",
        duration: "May 2025 – May 2026",
        description: [
            "Shipped a production Azure IoT Hub OTA pipeline with DPS auto-provisioning and HMAC-SHA256 device key derivation, cutting device onboarding to under 30 seconds and enabling fail-safe rollback on corrupt firmware",
            "Built Node.js suite scripts to load-test validating enrollment flows, message routing, and downstream processing.",
            "Implemented resilient MQTT device twin integration, including desired-property parsing & reported-property acknowledgments, token-refresh handling, and automatic reconnect logic for stable control in production.",
            "Automated web application deployment via GitHub Actions CI/CD pipeline that builds the React frontend, bundles it into the .NET publish artifact, and deploys to Azure App Service."
        ],
        technologies: ["Azure", "C/C++", "Espressif", "React", ".NET", "Docker"],
    },
    {
        logo: misdLogo,
        company: "MISD Technology",
        role: "IT Intern",
        duration: "Sept 2022 – May 2023",
        description: [
            "Managing district-wide hardware inventory, repairs, and IT support tasks for over 35000 students and 48 schools.",
            "Aided in the completion of 5 projects over a span of 2 months using technical skills regarding Active Directory and Group Policy, laptop hardware, software repair, and OS management.",
            "Collaborated with coworkers as a team to increase efficiency by 40% and finish projects ahead of deadlines."
        ],
        technologies: ["SQL", "Spreadsheets"],
    }

];
---

<div>
    {experiences.map((exp) => (
        <div class="py-5 flex flex-col gap-3">
            <!-- Left: company info -->
            <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                    {exp.logo ? (
                        <Image 
                            src={exp.logo} 
                            alt={`${exp.company} logo`}
                            width={32}
                            height={32}
                            densities={[1.5, 2]}
                            quality={100}
                            class="size-7 object-contain rounded"
                        />
                    ) : (
                        <span class="size-7 rounded bg-border flex items-center justify-center text-xs font-bold text-secondary shrink-0">
                            {exp.company[0]}
                        </span>
                    )}
                    <h3 class="font-medium text-primary">{exp.company}</h3>
                    <span class="text-secondary text-xs border border-border px-2 py-0.5 rounded-full">{exp.role}</span>
                    <span class="text-secondary text-xs ml-auto">{exp.duration}</span>
                </div>

                <!-- Description -->
                <ul class="mt-3 space-y-1.5 pl-3 sm:pl-9">
                    {exp.description.map((item) => (
                        <li class="text-sm text-primary/75 pl-3 border-l-2 border-accent/30 leading-relaxed">{item}</li>
                    ))}
                </ul>

                <!-- Technologies -->
                {exp.technologies && exp.technologies.length > 0 && (
                    <div class="mt-4 pl-3 sm:pl-9 flex flex-wrap gap-2">
                        {exp.technologies.map((tech) => (
                            <span class="text-xs text-secondary border border-border px-2 py-0.5 rounded font-mono">
                                {tech}
                            </span>
                        ))}
                    </div>
                )}
            </div>
        </div>
    ))}
</div>