---
import { Image } from "astro:assets";

import jpmcLogo from "@/content/experiences/jpmc.png";
import beautisolLogo from "@/content/experiences/beautisol.png";
import misdLogo from "@/content/experiences/misd.png";

interface Experience {
    logo?: ImageMetadata,
    company: string,
    role: string,
    duration: string,
    description: string[],
    technologies?: string[],    
    link?: string,
}

const experiences: Experience[] = [
    {
        company: "UR2PhD Program",
        role: "Research Participant",
        duration: "2025 – Present",
        description: [
            "Selected for a competitive undergraduate research-to-PhD pipeline program."
        ],
    },
    {
        company: "AWS Student Builder Campus Leader",
        role: "Campus Leader",
        duration: "2025 – Present",
        description: [
            "Representing AWS on campus, organizing cloud workshops and connecting students with AWS resources and programs."
        ],
        technologies: ["AWS"],
    },
    {
        logo: jpmcLogo,
        company: "JP Morgan Chase",
        role: "Incoming Software Engineer Intern",
        duration: "Summer 2026",
        description: [
            "Part of the SEP Program"
        ],
    },
    {
        logo: beautisolLogo,
        company: "Beautisol",
        role: "Software Development Intern",
        duration: "May 2025 – May 2026",
        description: [
            "Building out a customer-facing application showcasing products, and supporting future training and machine dashboards",
            "Engineered Azure IoT Hub OTA pipeline with device provisioning and device key derivation"
        ],
        technologies: ["Azure", "C++", "Espressif", "React", ".NET", "Docker"],
    },
    {
        logo: misdLogo,
        company: "MISD Technology",
        role: "IT Intern",
        duration: "Sept 2022 – May 2023",
        description: [
            "Managing district-wide hardware inventory, repairs, and IT support tasks."
        ],
        technologies: ["SQL", "Spreadsheets"],
    }

];
---

<div class="divide-y divide-border">
    {experiences.map((exp) => (
        <div class="py-8 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <!-- Left: company info -->
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-1">
                    {exp.logo ? (
                        <Image 
                            src={exp.logo} 
                            alt={`${exp.company} logo`}
                            width={20}
                            height={20}
                            densities={[1.5, 2]}
                            quality={100}
                            format="png"
                            class="rounded size-5"
                        />
                    ) : (
                        <span class="size-5 rounded bg-border flex items-center justify-center text-[10px] font-bold text-secondary shrink-0">
                            {exp.company[0]}
                        </span>
                    )}
                    <h3 class="font-medium text-primary">{exp.company}</h3>
                    <span class="text-secondary text-sm">·</span>
                    <span class="text-secondary text-sm">{exp.role}</span>
                </div>

                <!-- Description -->
                <ul class="mt-3 space-y-1.5 pl-8">
                    {exp.description.map((item) => (
                        <li class="text-sm text-primary/80 pl-3 border-l border-accent/40">{item}</li>
                    ))}
                </ul>

                <!-- Technologies -->
                {exp.technologies && exp.technologies.length > 0 && (
                    <div class="mt-4 pl-8 flex flex-wrap gap-2">
                        {exp.technologies.map((tech) => (
                            <span class="text-xs text-secondary border border-border px-2 py-0.5 rounded">
                                {tech}
                            </span>
                        ))}
                    </div>
                )}
            </div>

            <!-- Right: duration -->
            <div class="text-secondary text-sm whitespace-nowrap shrink-0 sm:text-right">
                {exp.duration}
            </div>
        </div>
    ))}
</div>