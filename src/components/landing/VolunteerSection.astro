---
import VolunteerCard from './VolunteerCard.astro'

export interface Props {
    headingStyle: string;
}

const { headingStyle } = Astro.props
---

<section id="volunteer" class="mt-0 py-12">
    <div class="px-5 sm:px-6 mx-auto max-w-5xl">
        <h2 class={headingStyle}>Volunteer</h2>
        <p class="text-sm text-secondary mb-8 max-w-xl">
            Some of my roles and opportunities in organizations and different projects!
        </p>
        <VolunteerCard/>
    </div>
</section>